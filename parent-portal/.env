# === PARENT PORTAL BACKEND ===

# Network
PORTAL_HOST=127.0.0.1
PORTAL_PORT=4000

# Isolated Database (CREATE 'scms_portal' in MySQL first!)
PORTAL_DB_HOST=127.0.0.1
PORTAL_DB_USER=root
PORTAL_DB_PASSWORD=Hayyan
PORTAL_DB_NAME=scms_portal

# Security
PORTAL_JWT_SECRET=portal_jwt_secret_make_this_long_and_random

# Must match PORTAL_API_KEY in main .env
ADMIN_API_KEY=scms_sync_secret_2024_change_this

# CORS
PARENT_PORTAL_URL=http://127.0.0.1:5174

# Upload config
UPLOAD_DIR=C:\Users\hayya\VSCode\SCMS\scmsForms
MAX_FILE_SIZE_MB=5

